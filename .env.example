# Environment variables for ProPlanner
# If you are deploying this application to your own host (Vercel, Netlify, Cloud Run, etc.),
# you must set the following environment variables in your hosting dashboard or .env file
# BEFORE running `npm run build`.

# Your Gemini API Key (Required for AI features)
# Get one from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration (Required for database)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
